---
import OceanCurrent from "~/components/ocean-current.astro";
import { useTranslations, asLang } from "~/i18n/utils";

const t = useTranslations(asLang(Astro.currentLocale));
---

<section class="relative z-10 h-full min-h-screen bg-black">
  <OceanCurrent />

  <div
    class="relative grid h-full min-h-screen place-items-center sm:grid-cols-2"
  >
    <!-- Left: Text content -->
    <h2
      class="flex flex-col items-center gap-6 self-end sm:gap-8 sm:self-auto sm:justify-self-end sm:pe-12"
    >
      <!-- <div class="flex items-center gap-3">
        <svg
          class="size-16 text-white md:size-24"
          viewBox="0 0 627 894"
          fill="currentColor"
        >
          <path
            d="M445.433 22.983c7.289 9.05 11.006 21.26 18.44 45.682l162.408 533.511a675.9 675.9 0 0 0-194.166-65.737l-105.744-357.34a13.763 13.763 0 0 0-26.408.041L195.5 536.259A675.8 675.8 0 0 0 .46 602.095L163.663 68.541c7.457-24.38 11.186-36.57 18.476-45.602A60 60 0 0 1 206.454 4.95C217.224.622 229.971.622 255.466.622h116.568c25.528 0 38.292 0 49.072 4.338a60 60 0 0 1 24.327 18.023"
          ></path>
          <path
            fill="#FF5D01"
            d="M464.867 627.566c-26.773 22.894-80.212 38.507-141.766 38.507-75.55 0-138.872-23.52-155.675-55.152-6.007 18.129-7.354 38.877-7.354 52.131 0 0-3.958 65.082 41.308 110.349 0-23.505 19.055-42.559 42.559-42.559 40.287 0 40.242 35.148 40.205 63.664l-.002 2.545c0 43.282 26.453 80.385 64.073 96.024-5.619-11.557-8.771-24.535-8.771-38.25 0-41.28 24.235-56.65 52.401-74.514 22.41-14.213 47.31-30.004 64.47-61.682 8.953-16.528 14.037-35.459 14.037-55.577 0-12.372-1.922-24.295-5.485-35.486"
          ></path>
        </svg>
      </div> -->
      <div
        class="text-center font-extrabold tracking-tighter text-white text-5xl sm:text-start md:text-7xl lg:text-8xl"
      >
        {t("splash.line1")}
        <br />
        {t("splash.line2")}
        <br />
        <span class="gradient-text">{t("splash.line3")}</span>
      </div>
    </h2>

    <!-- Right: Whale image -->
    <div
      id="whale-container"
      class="w-2/3 self-start sm:w-10/12 sm:self-auto sm:justify-self-start"
    >
      <img
        class="h-full w-full object-contain"
        src="/whale.webp"
        width="800"
        height="800"
        loading="eager"
        alt={t("splash.whale_alt")}
      />
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0% {
      transform: translate3d(0, 0, 0);
    }

    100% {
      transform: translate3d(0, 30px, 0);
    }
  }

  #whale-container {
    animation: float linear 2.5s infinite alternate;
  }

  @media (prefers-reduced-motion: reduce) {
    #whale-container {
      @apply animate-none;
    }

    :global(#ocean-current) {
      @apply hidden;
    }
  }
</style>
