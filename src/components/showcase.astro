---
import ContentSection from "~/components/content-section.astro";
---

<ContentSection title="See Payesh in Action" id="showcase">
  <Fragment slot="lead">
    Real <span class="text-primary">Telegram alerts</span> — exactly what
    you'll receive when a deposit lands.
  </Fragment>

  <div class="w-full max-w-5xl space-y-8">
    <!-- Alert Type Selector -->
    <div class="flex flex-wrap items-center justify-center gap-4">
      <button
        data-showcase-tab="deposit"
        class="showcase-tab rounded-full border border-primary/30 bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary transition-colors"
      >
        Deposit Alert
      </button>
      <button
        data-showcase-tab="daily"
        class="showcase-tab rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-sm font-semibold text-offset transition-colors hover:border-white/20"
      >
        Daily Report
      </button>
      <button
        data-showcase-tab="welcome"
        class="showcase-tab rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-sm font-semibold text-offset transition-colors hover:border-white/20"
      >
        Welcome Message
      </button>
    </div>

    <!-- Panel: Deposit Alert -->
    <div data-showcase-panel="deposit" class="showcase-panel mx-auto max-w-lg">
      <div
        class="overflow-hidden rounded-2xl border border-white/10 bg-[#17212b]"
      >
        <!-- Telegram Header -->
        <div
          class="flex items-center gap-3 border-b border-white/10 bg-[#1f2936] px-4 py-3"
        >
          <div
            class="flex size-10 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-purple-500"
          >
            <svg class="size-5 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
              ></path>
            </svg>
          </div>
          <div>
            <div class="font-bold text-sm text-white">
              Payesh | Crypto Deposit Monitor
            </div>
            <div class="text-xs text-gray-400">bot</div>
          </div>
        </div>

        <!-- Chat Messages -->
        <div class="space-y-3 p-4">
          <!-- Bot: Deposit Alert -->
          <div class="flex justify-start">
            <div
              class="max-w-[85%] rounded-2xl rounded-tl-sm bg-[#2b5278] p-4"
            >
              <!-- Bot name + admin badge -->
              <div class="mb-1 flex items-center gap-2">
                <span class="text-sm font-bold text-emerald-400">
                  Payesh Worker
                </span>
                <span
                  class="rounded bg-emerald-500/20 px-1.5 py-0.5 text-[10px] font-bold text-emerald-300"
                >
                  admin
                </span>
              </div>
              <div class="mb-2">
                <span class="text-base font-bold text-white">
                  &#9989; Deposit Successful
                </span>
                <br />
                <span class="text-sm text-gray-200">
                  26.0 USDT — Completed
                </span>
              </div>
              <div class="space-y-1 text-sm text-gray-200">
                <p>
                  <span class="text-gray-400">&#128230; Exchange:</span>
                  <span class="font-semibold text-white"> Toobit</span>
                </p>
                <p>
                  <span class="text-gray-400">&#128176; Balance:</span>
                  <span class="font-semibold text-white">
                    3,120.19 USDT
                  </span>
                </p>
                <p>
                  <span class="text-gray-400">&#127760; Network:</span>
                  <span class="font-semibold text-white"> BSC</span>
                </p>
                <p>
                  <span class="text-gray-400">&#128197; Date:</span>
                  <span class="font-semibold text-white">
                    2026-07-11 01:06:43
                  </span>
                </p>
              </div>
              <div class="mt-2 space-y-1 border-t border-white/10 pt-2 text-sm text-gray-200">
                <p>
                  <span class="text-gray-400">&#128232; To:</span>
                </p>
                <p
                  class="break-all font-mono text-[11px] leading-tight text-gray-300"
                >
                  0x5ce638e926eca68e76464c10d80dbf56f6fba60c
                </p>
                <p class="mt-1">
                  <span class="text-gray-400">&#128232; From:</span>
                </p>
                <p
                  class="break-all font-mono text-[11px] leading-tight text-gray-300"
                >
                  0xe2fc31f816a9b94326492132018c3aecc4a93ae1
                </p>
              </div>
              <div
                class="mt-2 border-t border-white/10 pt-2 text-sm text-gray-200"
              >
                <p>
                  <span class="text-gray-400">&#128279; TxID:</span>
                </p>
                <p
                  class="break-all font-mono text-[11px] leading-tight text-gray-300"
                >
                  0x2e9cdaf7aed00914bb5e2d8d6da456c71d3f3c36a8815aeb0dd1a771f0f6aca8
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Panel: Daily Report -->
    <div
      data-showcase-panel="daily"
      class="showcase-panel mx-auto hidden max-w-lg"
    >
      <div
        class="overflow-hidden rounded-2xl border border-white/10 bg-[#17212b]"
      >
        <!-- Telegram Header -->
        <div
          class="flex items-center gap-3 border-b border-white/10 bg-[#1f2936] px-4 py-3"
        >
          <div
            class="flex size-10 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-purple-500"
          >
            <svg class="size-5 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
              ></path>
            </svg>
          </div>
          <div>
            <div class="font-bold text-sm text-white">
              Payesh | Crypto Deposit Monitor
            </div>
            <div class="text-xs text-gray-400">bot</div>
          </div>
        </div>

        <!-- Chat Messages -->
        <div class="space-y-3 p-4">
          <!-- User clicks Report -->
          <div class="flex justify-end">
            <div
              class="rounded-2xl rounded-tr-sm bg-[#2b5278] px-4 py-2 text-sm font-semibold text-white"
            >
              &#128202; Report
            </div>
          </div>

          <!-- Bot: Generate Report prompt -->
          <div class="flex justify-start">
            <div
              class="max-w-[85%] rounded-2xl rounded-tl-sm bg-[#2b5278] p-4"
            >
              <div class="mb-2 flex items-center gap-2">
                <span class="text-lg">&#128202;</span>
                <span class="font-bold text-white">Generate Report</span>
              </div>
              <p class="mb-3 text-sm text-gray-200">
                Select the timeframe for your report:
              </p>
              <!-- Inline keyboard buttons -->
              <div class="space-y-1.5">
                <div
                  class="w-full rounded-lg border border-white/10 bg-[#1f2936] px-4 py-2 text-center text-sm font-medium text-white transition-colors hover:border-white/20"
                >
                  &#128202; Daily Report
                </div>
                <div
                  class="w-full rounded-lg border border-white/10 bg-[#1f2936] px-4 py-2 text-center text-sm font-medium text-white transition-colors hover:border-white/20"
                >
                  &#128202; Weekly Report
                </div>
                <div
                  class="w-full rounded-lg border border-white/10 bg-[#1f2936] px-4 py-2 text-center text-sm font-medium text-white transition-colors hover:border-white/20"
                >
                  &#128202; Monthly Report
                </div>
                <div
                  class="w-full rounded-lg border border-white/10 bg-[#1f2936] px-4 py-2 text-center text-sm font-medium text-gray-400 transition-colors hover:border-white/20"
                >
                  &lsaquo; Back
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Panel: Welcome Message -->
    <div
      data-showcase-panel="welcome"
      class="showcase-panel mx-auto hidden max-w-lg"
    >
      <div
        class="overflow-hidden rounded-2xl border border-white/10 bg-[#17212b]"
      >
        <!-- Telegram Header -->
        <div
          class="flex items-center gap-3 border-b border-white/10 bg-[#1f2936] px-4 py-3"
        >
          <div
            class="flex size-10 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-purple-500"
          >
            <svg class="size-5 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
              ></path>
            </svg>
          </div>
          <div>
            <div class="font-bold text-sm text-white">
              Payesh | Crypto Deposit Monitor
            </div>
            <div class="text-xs text-gray-400">bot</div>
          </div>
        </div>

        <!-- Chat Messages -->
        <div class="space-y-3 p-4">
          <!-- User sends /start -->
          <div class="flex justify-end">
            <div
              class="rounded-2xl rounded-tr-sm bg-[#2b5278] px-4 py-2 text-sm font-semibold text-white"
            >
              /start
            </div>
          </div>

          <!-- Bot: Welcome message -->
          <div class="flex justify-start">
            <div
              class="max-w-[85%] rounded-2xl rounded-tl-sm bg-[#2b5278] p-4"
            >
              <div class="mb-2">
                <span class="text-base font-bold text-white">
                  &#128075; Hello, Parham
                </span>
                <br />
                <span class="text-sm text-gray-200">
                  Welcome to Payesh!
                </span>
              </div>
              <div class="space-y-1 text-sm text-gray-200">
                <p>
                  &#128680;
                  <span class="font-bold text-white">Status:</span>
                  <span class="ml-1 font-semibold text-emerald-400">
                    &#128994; Active
                  </span>
                </p>
                <p>
                  &#128337;
                  <span class="font-bold text-white">Subscription:</span>
                  <span class="ml-1 font-semibold text-white">
                    1 Days Left
                  </span>
                </p>
              </div>
              <p class="mt-2 text-sm text-gray-200">
                What would you like to do?
              </p>
            </div>
          </div>

          <!-- Menu buttons (reply keyboard) -->
          <div class="flex flex-wrap justify-center gap-1.5 pt-1">
            <div
              class="w-full rounded-lg border border-white/10 bg-[#1f2936] px-3 py-2 text-center text-xs font-medium text-white"
            >
              &#128279; Connect Exchange
            </div>
            <div
              class="w-[calc(50%-3px)] rounded-lg border border-white/10 bg-[#1f2936] px-3 py-2 text-center text-xs font-medium text-white"
            >
              &#128203; My Exchanges
            </div>
            <div
              class="w-[calc(50%-3px)] rounded-lg border border-white/10 bg-[#1f2936] px-3 py-2 text-center text-xs font-medium text-white"
            >
              &#128179; Subscription
            </div>
            <div
              class="w-[calc(50%-3px)] rounded-lg border border-white/10 bg-[#1f2936] px-3 py-2 text-center text-xs font-medium text-white"
            >
              &#9881;&#65039; Settings
            </div>
            <div
              class="w-[calc(50%-3px)] rounded-lg border border-white/10 bg-[#1f2936] px-3 py-2 text-center text-xs font-medium text-white"
            >
              &#128202; Report
            </div>
            <div
              class="w-[calc(50%-3px)] rounded-lg border border-white/10 bg-[#1f2936] px-3 py-2 text-center text-xs font-medium text-white"
            >
              &#127873; Free Trial
            </div>
            <div
              class="w-[calc(50%-3px)] rounded-lg border border-white/10 bg-[#1f2936] px-3 py-2 text-center text-xs font-medium text-white"
            >
              &#128172; Support
            </div>
          </div>
        </div>
      </div>
    </div>

    <p class="text-center text-sm text-offset">
      All alerts include full transaction details, TxID links, and USDT
      conversion values.
    </p>
  </div>
</ContentSection>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".showcase-tab");
  const panels = document.querySelectorAll<HTMLElement>(".showcase-panel");

  function switchTab(name: string) {
    tabs.forEach((tab) => {
      const isActive = tab.dataset.showcaseTab === name;
      tab.classList.toggle("border-primary/30", isActive);
      tab.classList.toggle("bg-primary/10", isActive);
      tab.classList.toggle("text-primary", isActive);
      tab.classList.toggle("border-white/10", !isActive);
      tab.classList.toggle("bg-white/5", !isActive);
      tab.classList.toggle("text-offset", !isActive);
    });

    panels.forEach((panel) => {
      panel.classList.toggle("hidden", panel.dataset.showcasePanel !== name);
    });
  }

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      switchTab(tab.dataset.showcaseTab!);
    });
  });
</script>
