---
import { useTranslations, asLang, getLocalizedUrl } from "~/i18n/utils";

const lang = asLang(Astro.currentLocale);
const t = useTranslations(lang);
const other = lang === "fa" ? "en" : "fa";
const href = getLocalizedUrl(other, "/");
const label = t("switcher.aria");
---

<a
  href={href}
  data-lang-switch={other}
  class="lang-switch inline-flex size-9 items-center justify-center rounded-lg text-offset transition-colors hover:bg-white/5 hover:text-primary"
  hreflang={other}
  aria-label={label}
  title={label}
>
  <svg
    class="size-5"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="10"></circle>
    <path d="M2 12h20"></path>
    <path
      d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
    ></path>
  </svg>
</a>

<script>
  // Persist an explicit language choice so the geo Worker doesn't override it.
  document.querySelectorAll<HTMLAnchorElement>(".lang-switch").forEach((el) => {
    el.addEventListener("click", () => {
      const lang = el.dataset.langSwitch;
      document.cookie = `lang=${lang}; path=/; max-age=31536000; samesite=lax`;
    });
  });
</script>
