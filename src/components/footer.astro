---
import { useTranslations, asLang, toFaDigits } from "~/i18n/utils";

const lang = asLang(Astro.currentLocale);
const t = useTranslations(lang);
const year = new Date().getFullYear();
const yearStr = lang === "fa" ? toFaDigits(year) : String(year);

const socialLinks = [
  {
    url: "https://t.me/PayeshBot",
    label: "Telegram Bot",
    icon: "telegram",
  },
  {
    url: "https://t.me/PayeshChannel",
    label: "Telegram Channel",
    icon: "channel",
  },
];
