<div id="ocean-current" class="absolute inset-0 pointer-events-none">
  <canvas id="ocean-canvas"></canvas>
</div>

<script>
  const PARTICLE_COUNT = 200;
  const MIN_SPEED = 0.2;
  const MAX_SPEED = 0.8;
  const MIN_SIZE = 1;
  const MAX_SIZE = 3;
  const MIN_OPACITY = 0.1;
  const MAX_OPACITY = 0.4;

  class Particle {
    x: number;
    y: number;
    size: number;
    speedX: number;
    opacity: number;
    bobOffset: number;
    bobSpeed: number;
    bobAmplitude: number;

    constructor(width: number, height: number) {
      this.x = Math.random() * width;
      this.y = Math.random() * height;
      this.size = MIN_SIZE + Math.random() * (MAX_SIZE - MIN_SIZE);
      this.speedX = MIN_SPEED + Math.random() * (MAX_SPEED - MIN_SPEED);
      this.opacity = MIN_OPACITY + Math.random() * (MAX_OPACITY - MIN_OPACITY);
      this.bobOffset = Math.random() * Math.PI * 2;
      this.bobSpeed = 0.01 + Math.random() * 0.02;
      this.bobAmplitude = 5 + Math.random() * 10;
    }

    update(width: number, height: number, time: number) {
      this.x += this.speedX;
      this.y += Math.sin(time * this.bobSpeed + this.bobOffset) * 0.3;

      if (this.x > width + this.size) {
        this.x = -this.size;
        this.y = Math.random() * height;
      }
      if (this.x < -this.size) {
        this.x = width + this.size;
        this.y = Math.random() * height;
      }
    }

    draw(ctx: CanvasRenderingContext2D) {
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(0, 212, 170, ${this.opacity})`;
      ctx.fill();
    }
  }

  const canvas = document.querySelector("#ocean-canvas") as HTMLCanvasElement;
  if (!canvas) throw new Error("canvas should not be null");
  const ctx = canvas.getContext("2d");

  const container = document.querySelector("#ocean-current") as HTMLElement;
  if (!container) throw new Error("container should not be null");

  let particles: Particle[] = [];
  let rafId = 0;
  let time = 0;

  const resizeObserver = new ResizeObserver(setup);
  resizeObserver.observe(container);

  function setup() {
    if (!ctx) return;
    rafId > 0 && cancelAnimationFrame(rafId);

    const { clientWidth: width, clientHeight: height } = container;
    const dpr = window.devicePixelRatio || 1;
    canvas.width = width * dpr;
    canvas.height = height * dpr;
    canvas.style.width = `${width}px`;
    canvas.style.height = `${height}px`;
    ctx.scale(dpr, dpr);

    particles = Array.from({ length: PARTICLE_COUNT }, () =>
      new Particle(width, height),
    );

    rafId = requestAnimationFrame(frame);
  }

  function frame() {
    if (!ctx) return;
    const { clientWidth: width, clientHeight: height } = container;

    ctx.clearRect(0, 0, width, height);
    time++;

    for (const particle of particles) {
      particle.update(width, height, time);
      particle.draw(ctx);
    }

    rafId = requestAnimationFrame(frame);
  }
</script>
