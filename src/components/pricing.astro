---
import ContentSection from "~/components/content-section.astro";
import { useTranslations, asLang } from "~/i18n/utils";

const t = useTranslations(asLang(Astro.currentLocale));

const plans = [
  { id: "free", featureCount: 4, badge: false },
  { id: "monthly", featureCount: 4, badge: true },
  { id: "annual", featureCount: 3, badge: true },
];

const telegramUrl = (msg: string) =>
  `https://t.me/payeshhelp?text=${encodeURIComponent(msg)}`;
---

<ContentSection title={t("pricing.title")} id="pricing">
  <Fragment slot="lead" set:html={t("pricing.lead")} />
  <ul class="grid max-w-5xl grid-cols-1 gap-6 md:grid-cols-3">
    {
      plans.map((plan, i) => (
        <li class="glow-card group flex flex-col p-8 transition-all duration-300 hover:border-white/20 hover:bg-white/10">
          <span
            class={`mb-4 w-fit rounded-full px-3 py-1 font-semibold text-xs ${plan.badge ? "bg-primary/20 text-primary" : "invisible"}`}
          >
            {plan.badge ? t(`pricing.${plan.id}.badge`) : "placeholder"}
          </span>
          <h3 class="mb-2 font-extrabold text-default text-xl">
            {t(`pricing.${plan.id}.name`)}
          </h3>
          <div class="mb-6">
            <span class="font-extrabold text-4xl">
              {t(`pricing.${plan.id}.price`)}
            </span>
            <span class="mx-1 text-offset text-sm">
              {t(`pricing.${plan.id}.period`)}
            </span>
          </div>
          <ul class="mb-8 flex-1 space-y-3">
            {Array.from({ length: plan.featureCount }, (_, n) => (
              <li class="flex items-start gap-2 text-sm">
                <svg
                  class="mt-0.5 size-4 shrink-0 text-primary"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                <span class="text-offset">
                  {t(`pricing.${plan.id}.f${n + 1}`)}
                </span>
              </li>
            ))}
          </ul>
          <a
            href={telegramUrl(t(`pricing.${plan.id}.message`))}
            target="_blank"
            rel="noopener noreferrer"
            class={`block w-full rounded-xl py-3 text-center font-semibold transition-all duration-300 ${
              i === 1
                ? "shadow-primary/25 hover:bg-primary/90 bg-primary text-white shadow-lg"
                : "hover:border-primary/30 hover:bg-primary/10 border border-white/10 bg-white/5 text-default"
            }`}
          >
            {t("pricing.cta")}
          </a>
        </li>
      ))
    }
  </ul>
</ContentSection>
