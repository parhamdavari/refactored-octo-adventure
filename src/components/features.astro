---
import ContentSection from "~/components/content-section.astro";
import { useTranslations, asLang } from "~/i18n/utils";

const t = useTranslations(asLang(Astro.currentLocale));

const features = [
  { id: "f1", icon: "monitor", color: "from-emerald-500 to-teal-500" },
  { id: "f2", icon: "alert", color: "from-violet-500 to-purple-500" },
  { id: "f3", icon: "report", color: "from-cyan-500 to-blue-500" },
  { id: "f4", icon: "shield", color: "from-amber-500 to-orange-500" },
];
---

<ContentSection title={t("features.title")} id="features">
  <Fragment slot="lead" set:html={t("features.lead")} />
  <ul class="grid max-w-5xl grid-cols-1 gap-6 md:grid-cols-2">
    {
      features.map(({ id, icon, color }) => (
        <li class="glow-card hover:border-primary/20 group p-8 transition-all duration-300">
          <div class="mb-4 flex items-center gap-4">
            <div
              class={`flex size-12 items-center justify-center rounded-xl bg-gradient-to-br ${color} p-2.5`}
            >
              {icon === "monitor" && (
                <svg
                  class="size-full text-white"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="2" y="3" width="20" height="14" rx="2" />
                  <line x1="8" y1="21" x2="16" y2="21" />
                  <line x1="12" y1="17" x2="12" y2="21" />
                </svg>
              )}
              {icon === "alert" && (
                <svg
                  class="size-full text-white"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                  <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                </svg>
              )}
              {icon === "report" && (
                <svg
                  class="size-full text-white"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                  <polyline points="14 2 14 8 20 8" />
                  <line x1="16" y1="13" x2="8" y2="13" />
                  <line x1="16" y1="17" x2="8" y2="17" />
                  <polyline points="10 9 9 9 8 9" />
                </svg>
              )}
              {icon === "shield" && (
                <svg
                  class="size-full text-white"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  <polyline points="9 12 11 14 15 10" />
                </svg>
              )}
            </div>
            <h3 class="font-extrabold text-xl">{t(`features.${id}.title`)}</h3>
          </div>
          <p class="leading-relaxed text-offset">{t(`features.${id}.desc`)}</p>
        </li>
      ))
    }
  </ul>
</ContentSection>
