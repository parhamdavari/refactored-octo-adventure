---
import ContentSection from "~/components/content-section.astro";

// Added 'icon' paths. Make sure these match the exact filenames
// and extensions (.svg, .png, etc.) you have in your public/ folder.
const exchanges = [
  { name: "Binance", color: "#F0B90B", icon: "/binance.jpeg" },
  { name: "KuCoin", color: "#23AF5A", icon: "/kucoin.png" },
  { name: "Toobit", color: "#00D4AA", icon: "/toobit.jpeg" },
  { name: "BingX", color: "#00D4AA", icon: "/bingx.jpeg" },
];

const networks = [
  { name: "BSC / BEP20", color: "#F0B90B", icon: "/bsc.svg" },
  { name: "TRC20", color: "#FF0013", icon: "/tron.svg" },
];
---

<ContentSection title="Supported Exchanges & Networks" id="compatibility">
  <Fragment slot="lead">
    Connect to <span class="text-primary">major exchanges</span> and monitor deposits
    across <span class="text-primary">popular networks</span>.
  </Fragment>

  <div class="w-full max-w-5xl space-y-8">
    <div class="glow-card p-8">
      <h3
        class="mb-6 text-center font-extrabold uppercase tracking-widest text-offset text-sm"
      >
        Supported Exchanges
      </h3>
      <ul class="grid grid-cols-2 gap-6 md:grid-cols-4">
        {
          exchanges.map(({ name, icon }) => (
            <li class="flex flex-col items-center gap-3">
              <div class="flex size-16 items-center justify-center rounded-2xl border border-white/10 bg-white/5 p-3 transition-all duration-300 hover:border-white/20 hover:bg-white/10">
                <img
                  src={icon}
                  alt={`${name} logo`}
                  class="h-full w-full object-contain"
                  loading="lazy"
                />
              </div>
              <span class="font-semibold text-offset text-sm">{name}</span>
            </li>
          ))
        }
      </ul>
    </div>
    <!-- Networks -->
    <div class="glow-card p-8">
      <h3
        class="mb-6 text-center font-extrabold uppercase tracking-widest text-offset text-sm"
      >
        Supported Networks
      </h3>
      <ul class="flex flex-wrap items-center justify-center gap-8">
        {
          networks.map(({ name, color }) => (
            <li class="flex items-center gap-3">
              <div class="flex size-12 items-center justify-center rounded-xl border border-white/10 bg-white/5 p-2.5 transition-all duration-300 hover:border-white/20 hover:bg-white/10">
                <span class="font-extrabold text-xs" style={`color: ${color}`}>
                  {name.split(" ")[0]}
                </span>
              </div>
              <span class="font-semibold text-offset text-sm">{name}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</ContentSection>
